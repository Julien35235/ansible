// ============================================================
// GRAFANA ALLOY — {{ inventory_hostname }}
// Généré par Ansible — ne pas modifier manuellement
// ============================================================

// ==================== LOGS ====================

// Fichiers syslog
local.file_match "system_logs" {
  path_targets = [
    {
      __path__ = "/var/log/syslog",
      job      = "syslog",
      host     = "{{ inventory_hostname }}",
      env      = "production",
    },
    {
      __path__ = "/var/log/auth.log",
      job      = "auth_log",
      host     = "{{ inventory_hostname }}",
      env      = "production",
    },
  ]
}

loki.source.file "system_logs" {
  targets    = local.file_match.system_logs.targets
  forward_to = [loki.write.loki_push.receiver]
}

// Journald
loki.source.journal "journal" {
  forward_to = [loki.write.loki_push.receiver]
  labels     = {
    job  = "systemd-journal",
    host = "{{ inventory_hostname }}",
    env  = "production",
  }
}

// Conteneurs Docker
discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "docker_meta" {
  targets = []

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  rule {
    source_labels = ["__meta_docker_compose_service"]
    target_label  = "service"
  }

  rule {
    source_labels = ["__meta_docker_compose_project"]
    target_label  = "compose_project"
  }
}

loki.source.docker "docker_logs" {
  host          = "unix:///var/run/docker.sock"
  targets       = discovery.docker.containers.targets
  forward_to    = [loki.write.loki_push.receiver]
  relabel_rules = discovery.relabel.docker_meta.rules
  labels        = {
    job  = "docker",
    host = "{{ inventory_hostname }}",
    env  = "production",
  }
}

// ==================== MÉTRIQUES ====================

prometheus.exporter.unix "node" {
  enable_collectors = ["cpu", "meminfo", "filesystem", "netdev", "loadavg", "systemd"]
}

prometheus.scrape "node_exporter" {
  targets         = prometheus.exporter.unix.node.targets
  forward_to      = [prometheus.relabel.add_labels.receiver]
  job_name        = "node_exporter"
  scrape_interval = "15s"
}

prometheus.relabel "add_labels" {
  forward_to = [prometheus.remote_write.prometheus_push.receiver]

  rule {
    target_label = "host"
    replacement  = "{{ inventory_hostname }}"
  }

  rule {
    target_label = "env"
    replacement  = "production"
  }

  rule {
    target_label = "job"
    replacement  = "node_exporter"
  }
}

// ==================== OUTPUTS ====================

loki.write "loki_push" {
  endpoint {
    url = "{{ loki_url }}/loki/api/v1/push"
  }
  external_labels = {
    env  = "production",
  }
}

prometheus.remote_write "prometheus_push" {
  endpoint {
    url = "{{ prometheus_url }}"
  }
}
